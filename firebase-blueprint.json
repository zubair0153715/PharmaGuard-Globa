{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["QA_Manager", "Regulatory_Officer", "Reviewer", "Admin"] },
        "tenantId": { "type": "string", "description": "Company/Tenant ID for isolation" },
        "companyName": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["trial", "active", "past_due", "canceled"] },
        "stripeCustomerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "ValidationSubmission": {
      "title": "Validation Submission",
      "description": "Stores the results of a document validation.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Document ID" },
        "uid": { "type": "string", "description": "Owner UID" },
        "tenantId": { "type": "string", "description": "Tenant ID for isolation" },
        "fileName": { "type": "string" },
        "checksum": { "type": "string" },
        "healthScore": { "type": "number" },
        "status": { "type": "string", "enum": ["Pass", "Fail"] },
        "isPdfA": { "type": "boolean" },
        "pdfAStandard": { "type": "string" },
        "pdfAIssues": { "type": "array" },
        "isFileNameValid": { "type": "boolean" },
        "pageCount": { "type": "number" },
        "metadata": { "type": "object" },
        "aiAnalysis": {
          "type": "object",
          "properties": {
            "productName": { "type": "string" },
            "batchNumber": { "type": "string" },
            "stabilityStudyFound": { "type": "boolean" },
            "summary": { "type": "string" },
            "confidenceScore": { "type": "number" }
          }
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "type": { "type": "string", "enum": ["info", "warning", "error"] },
              "action": { "type": "string" }
            }
          }
        },
        "deepAudit": {
          "type": "object",
          "properties": {
            "report": { "type": "string" },
            "nextSteps": { "type": "array", "items": { "type": "string" } },
            "complianceStatus": { "type": "string", "enum": ["Compliant", "Non-Compliant", "Warning"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isFixed": { "type": "boolean" },
        "correctedData": { "type": "object" },
        "isSigned": { "type": "boolean" },
        "signatureId": { "type": "string" }
      },
      "required": ["uid", "fileName", "healthScore", "status", "createdAt"]
    },
    "AuditTrail": {
      "title": "Audit Trail",
      "description": "21 CFR Part 11 compliant audit log of all system actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string", "description": "User who performed the action" },
        "tenantId": { "type": "string", "description": "Tenant ID for isolation" },
        "userEmail": { "type": "string" },
        "action": { "type": "string", "description": "Action performed (e.g., 'UPLOAD', 'SIGN', 'DELETE')" },
        "resourceType": { "type": "string", "description": "Type of resource affected" },
        "resourceId": { "type": "string", "description": "ID of resource affected" },
        "details": { "type": "string", "description": "Human-readable description of the change" },
        "previousState": { "type": "object", "description": "Data before change" },
        "newState": { "type": "object", "description": "Data after change" },
        "ipAddress": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "action", "resourceType", "timestamp"]
    },
    "Signature": {
      "title": "Electronic Signature",
      "description": "21 CFR Part 11 compliant electronic signature record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "tenantId": { "type": "string", "description": "Tenant ID for isolation" },
        "userEmail": { "type": "string" },
        "submissionId": { "type": "string" },
        "reason": { "type": "string", "description": "Reason for signing (e.g., 'Review', 'Approval')" },
        "meaning": { "type": "string", "description": "Regulatory meaning of signature" },
        "timestamp": { "type": "string", "format": "date-time" },
        "hash": { "type": "string", "description": "Cryptographic hash of the document at time of signing" }
      },
      "required": ["uid", "submissionId", "reason", "timestamp"]
    },
    "CustomRule": {
      "title": "Custom Validation Rule",
      "description": "User-defined validation rules for SFDA guidelines.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "tenantId": { "type": "string", "description": "Tenant ID for isolation" },
        "name": { "type": "string", "description": "Rule name (e.g., 'Batch Number Format')" },
        "description": { "type": "string", "description": "What the rule checks" },
        "logic": { "type": "string", "description": "Natural language description of the logic for AI to follow" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "logic", "severity", "isActive"]
    },
    "CAPARecord": {
      "title": "CAPA Record",
      "description": "Corrective and Preventive Action records.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In_Progress", "Resolved", "Verified"] },
        "severity": { "type": "string", "enum": ["Critical", "Major", "Minor"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "status", "severity"]
    },
    "TrainingRecord": {
      "title": "Training Record",
      "description": "Records of user training completions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "tenantId": { "type": "string" },
        "documentTitle": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "documentTitle", "completedAt"]
    },
    "Vendor": {
      "title": "Vendor Profile",
      "description": "Information about qualified vendors and suppliers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "riskLevel": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "status": { "type": "string", "enum": ["Qualified", "On_Watch", "Disqualified"] },
        "lastAuditAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "status"]
    },
    "ChangeControl": {
      "title": "Change Control",
      "description": "Formal change management records.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Pending_Approval", "Implemented", "Closed"] },
        "impactAnalysis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "status"]
    },
    "StabilityStudy": {
      "title": "Stability Study",
      "description": "Long-term drug stability project tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "productName": { "type": "string" },
        "batchNumber": { "type": "string" },
        "condition": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Completed", "Failed"] }
      },
      "required": ["uid", "productName", "batchNumber", "status"]
    },
    "AssetCalibration": {
      "title": "Asset Calibration",
      "description": "Equipment calibration and maintenance tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "assetId": { "type": "string" },
        "assetName": { "type": "string" },
        "nextCalibrationDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Valid", "Expired", "Pending"] }
      },
      "required": ["uid", "assetId", "assetName", "status"]
    },
    "BatchRelease": {
      "title": "Batch Release",
      "description": "Final QP certification and market release record.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "batchNumber": { "type": "string" },
        "productName": { "type": "string" },
        "finalReleaseStatus": { "type": "string", "enum": ["Released", "Quarantined", "Rejected", "Pending"] }
      },
      "required": ["uid", "batchNumber", "productName", "finalReleaseStatus"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/submissions/{submissionId}": {
      "schema": "ValidationSubmission",
      "description": "Validation result documents"
    },
    "/rules/{ruleId}": {
      "schema": "CustomRule",
      "description": "Custom validation rules"
    },
    "/audit_trail/{logId}": {
      "schema": "AuditTrail",
      "description": "21 CFR Part 11 Audit Trail logs"
    },
    "/signatures/{signatureId}": {
      "schema": "Signature",
      "description": "Electronic signature records"
    },
    "/capas/{capaId}": {
      "schema": "CAPARecord",
      "description": "CAPA records"
    },
    "/training_records/{recordId}": {
      "schema": "TrainingRecord",
      "description": "Training completion records"
    },
    "/vendors/{vendorId}": {
      "schema": "Vendor",
      "description": "Vendor management records"
    },
    "/change_controls/{ccId}": {
      "schema": "ChangeControl",
      "description": "Change management records"
    },
    "/stability_studies/{studyId}": {
      "schema": "StabilityStudy",
      "description": "Stability study records"
    },
    "/asset_calibrations/{assetId}": {
      "schema": "AssetCalibration",
      "description": "Asset calibration records"
    },
    "/batch_releases/{releaseId}": {
      "schema": "BatchRelease",
      "description": "Batch release process records"
    },
    "/logs/{logId}": {
      "schema": {
        "title": "AppLog",
        "type": "object",
        "properties": {
          "level": { "type": "string", "enum": ["info", "warn", "error"] },
          "category": { "type": "string" },
          "message": { "type": "string" },
          "stack": { "type": "string" },
          "uid": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "metadata": { "type": "object" }
        },
        "required": ["level", "category", "message", "timestamp"]
      },
      "description": "Centralized application logs for monitoring"
    }
  }
}
